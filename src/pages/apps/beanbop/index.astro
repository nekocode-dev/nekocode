---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BeanBopNav from '@/components/nav/BeanBopNav.astro';
import Footer from '@/components/nav/Footer.astro';
import Container from '@/components/layout/Container.astro';
import Section from '@/components/layout/Section.astro';
import Button from '@/components/ui/Button.astro';
import Tag from '@/components/ui/Tag.astro';

const base = import.meta.env.BASE_URL;

const features = [
  {
    icon: '☕',
    title: 'Fast Drink Logging',
    description: 'Track coffee, tea, soda, and energy drinks in just a few taps.'
  },
  {
    icon: '🧠',
    title: 'Sleep Shield',
    description: 'See estimated caffeine in your body before bedtime.'
  },
  {
    icon: '📱',
    title: 'Local-First Storage',
    description: 'Your logs and preferences stay on your device by default.'
  },
  {
    icon: '💧',
    title: 'Hydration Tracking',
    description: 'Log water alongside caffeine for better daily balance.'
  },
  {
    icon: '📊',
    title: 'Zone Insights',
    description: 'Visual caffeine zones make your daily status easy to understand.'
  },
  {
    icon: '🗂️',
    title: 'Import / Export',
    description: 'Move your data in and out when you want, on your terms.'
  }
];

const stats = [
  { value: 'Offline', label: 'First' },
  { value: '4', label: 'Caffeine Zones' },
  { value: 'Private', label: 'By Default' },
  { value: 'Fast', label: 'Daily Logging' },
];

const heroImage = `${base}assets/projects/beanbop/cover.webp`;
const appLogo = `${base}assets/projects/beanbop/logo.webp`;

const googlePlayUrl = '';
const appStoreUrl = '';
---

<BaseLayout
  title="BeanBop | Coffee Tracker"
  description="BeanBop is a cute local-first coffee and caffeine tracker with sleep-aware insights and private on-device data."
>
  <BeanBopNav slot="header" />

  <Section size="xl" class="hero-section">
    <Container>
      <div class="hero-grid">
        <div class="hero-content reveal-left">
          <div class="hero-badge">
            <span>☕ Local-First • Sleep-Aware Insights</span>
          </div>

          <h1 class="text-hero">
            <span class="gradient-text">Track Caffeine</span><br/>
            Without the Noise
          </h1>

          <p class="hero-description">
            BeanBop helps you log drinks fast, understand your daily caffeine zone,
            and make better decisions before bedtime. Built to stay private and useful.
          </p>

          <div class="hero-actions">
            <Button href="#download" variant="accent" size="lg">Get BeanBop</Button>
            <Button href="#features" variant="secondary" size="lg">Explore Features</Button>
          </div>
        </div>

        <div class="phone-mockup reveal-right">
          <div class="phone-glow"></div>
          <div class="phone-frame">
            <div class="phone-screen" style={`--screen-image: url('${appLogo}')`}>
              <div class="phone-content">
                <img src={appLogo} alt="BeanBop app logo" class="mockup-icon" />
                <span class="mockup-name">BeanBop</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </Container>
  </Section>

  <Section class="stats-section">
    <Container size="narrow">
      <div class="stats-grid glass-panel">
        {stats.map((stat, index) => (
          <div class={`stat-item reveal stagger-${index + 1}`}>
            <div class="stat-value">{stat.value}</div>
            <div class="stat-label">{stat.label}</div>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  <Section id="features" size="lg" class="features-section">
    <Container>
      <div class="section-header reveal">
        <Tag variant="accent">Features</Tag>
        <h2 class="text-title-1">Built for daily caffeine awareness</h2>
        <p class="section-subtitle">Simple flow, practical insights, and local-first privacy.</p>
      </div>

      <div class="features-grid">
        {features.map(feature => (
          <article class="feature-card">
            <span class="feature-icon">{feature.icon}</span>
            <h3>{feature.title}</h3>
            <p>{feature.description}</p>
          </article>
        ))}
      </div>
    </Container>
  </Section>

  <Section id="download" size="lg" class="download-section">
    <Container size="narrow">
      <div class="download-card glass-panel">
        <img src={`${base}assets/projects/beanbop/logo.webp`} alt="BeanBop" class="download-icon" />
        <h2 class="text-title-1">Get BeanBop</h2>
        <p class="download-description">
          BeanBop is currently in development. Store links will be available at launch.
        </p>

        <div class="download-buttons">
          {googlePlayUrl ? (
            <a href={googlePlayUrl} target="_blank" rel="noopener noreferrer" class="store-button">Google Play</a>
          ) : (
            <button disabled class="store-button disabled">Android Coming Soon</button>
          )}

          {appStoreUrl ? (
            <a href={appStoreUrl} target="_blank" rel="noopener noreferrer" class="store-button">App Store</a>
          ) : (
            <button disabled class="store-button disabled">iOS Coming Soon</button>
          )}
        </div>

        <p class="download-note">Privacy-first • Local-first • No required account</p>
      </div>
    </Container>
  </Section>

  <Section class="legal-section">
    <Container size="narrow">
      <div class="legal-links">
        <a href={`${base}apps/beanbop/privacy`}>Privacy Policy</a>
        <span class="divider">•</span>
        <a href={`${base}apps/beanbop/terms`}>Terms of Service</a>
      </div>
    </Container>
  </Section>

  <Footer slot="footer" />
</BaseLayout>

<script>
  const initBeanBopHeroTilt = () => {
    const heroSection = document.querySelector('.hero-section');
    const phoneFrame = document.querySelector('.phone-frame');

    if (!heroSection || !phoneFrame) return;

    const handleMouseMove = (e) => {
      const { left, top, width, height } = heroSection.getBoundingClientRect();
      const x = (e.clientX - left) / width - 0.5;
      const y = (e.clientY - top) / height - 0.5;

      const tiltX = y * -20;
      const tiltY = x * 20;

      phoneFrame.style.setProperty('--tilt-x', `${tiltX}deg`);
      phoneFrame.style.setProperty('--tilt-y', `${tiltY}deg`);
    };

    const handleMouseLeave = () => {
      phoneFrame.style.setProperty('--tilt-x', '0deg');
      phoneFrame.style.setProperty('--tilt-y', '0deg');
    };

    heroSection.addEventListener('mousemove', handleMouseMove);
    heroSection.addEventListener('mouseleave', handleMouseLeave);
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initBeanBopHeroTilt, { once: true });
  } else {
    initBeanBopHeroTilt();
  }
  document.addEventListener('astro:page-load', initBeanBopHeroTilt);
</script>

<style>
  .glass-panel {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-xl);
  }

  [data-theme="light"] .glass-panel {
    background: rgba(255, 255, 255, 0.85);
    border-color: rgba(0, 0, 0, 0.08);
  }

  .hero-section {
    position: relative;
    overflow: hidden;
  }

  .hero-section::before {
    content: '';
    position: absolute;
    top: 12%;
    left: 14%;
    width: 380px;
    height: 380px;
    background: radial-gradient(circle, rgba(164, 107, 69, 0.24) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-section::after {
    content: '';
    position: absolute;
    bottom: 6%;
    right: 12%;
    width: 420px;
    height: 420px;
    background: radial-gradient(circle, rgba(243, 182, 122, 0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  @media (max-width: 768px) {
    .hero-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }
  }

  .hero-badge {
    display: inline-block;
    padding: var(--space-2) var(--space-4);
    background: rgba(164, 107, 69, 0.18);
    border: 1px solid rgba(164, 107, 69, 0.4);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    color: #f4c798;
    margin-bottom: var(--space-6);
  }

  [data-theme="light"] .hero-badge {
    color: #8a4d2c;
  }

  .gradient-text {
    background: linear-gradient(135deg, #f4c798, #da9f6f);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-content h1 {
    margin-bottom: var(--space-6);
  }

  .hero-description {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: var(--space-8);
    max-width: 520px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  @media (max-width: 768px) {
    .hero-description {
      margin-inline: auto;
    }

    .hero-actions {
      justify-content: center;
    }
  }

  .phone-mockup {
    display: flex;
    justify-content: center;
    position: relative;
    perspective: 1000px;
    z-index: 10;
  }

  .phone-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 340px;
    height: 600px;
    background: radial-gradient(ellipse, rgba(166, 102, 58, 0.35) 0%, transparent 70%);
    filter: blur(45px);
    pointer-events: none;
    z-index: -1;
  }

  .phone-frame {
    background: #000;
    border-radius: 50px;
    padding: 12px;
    box-shadow:
      0 0 0 2px #333,
      0 0 0 4px #1a1a1a,
      0 24px 48px rgba(0, 0, 0, 0.45);
    transform-style: preserve-3d;
    transform: rotateX(var(--tilt-x, 0deg)) rotateY(var(--tilt-y, 0deg));
    transition: transform 0.1s cubic-bezier(0.2, 0, 0.2, 1);
    width: 300px;
    height: 600px;
    position: relative;
    will-change: transform;
  }

  .phone-frame::before {
    content: '';
    position: absolute;
    top: 24px;
    left: 50%;
    transform: translateX(-50%);
    width: 90px;
    height: 24px;
    background: #000;
    border-radius: 12px;
    z-index: 20;
  }

  .phone-frame::after {
    content: '';
    position: absolute;
    top: 100px;
    right: -6px;
    width: 4px;
    height: 60px;
    background: #2a2a2a;
    border-radius: 2px;
  }

  .phone-screen {
    width: 100%;
    height: 100%;
    border-radius: 40px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: linear-gradient(180deg, #1a1a24 0%, #222230 100%);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .phone-screen::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: var(--screen-image);
    background-position: center;
    background-size: cover;
    filter: blur(26px) saturate(1.2);
    transform: scale(1.08);
    opacity: 0.75;
  }

  .phone-screen::after {
    content: '';
    position: absolute;
    top: -50%;
    left: -100%;
    width: 200%;
    height: 200%;
    background: linear-gradient(
      45deg,
      transparent 40%,
      rgba(255, 255, 255, 0.05) 45%,
      transparent 50%
    );
    transform: rotate(25deg);
    pointer-events: none;
    z-index: 3;
  }

  .phone-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-8);
    transform: translateZ(20px);
  }

  .mockup-icon {
    width: 120px;
    height: 120px;
    border-radius: 28px;
    object-fit: cover;
    box-shadow:
      0 8px 24px rgba(0, 0, 0, 0.3),
      0 16px 48px rgba(0, 0, 0, 0.2);
    animation: float 6s ease-in-out infinite;
  }

  .mockup-name {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: 800;
    background: linear-gradient(135deg, #fff 0%, #e0e0e0 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    text-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
    letter-spacing: -0.03em;
  }

  .stats-section {
    padding-top: 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--space-4);
    padding: var(--space-6);
  }

  @media (max-width: 768px) {
    .stats-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .stat-item {
    text-align: center;
  }

  .stat-value {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 700;
    color: var(--color-accent);
  }

  .stat-label {
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--space-10);
  }

  .section-header h2 {
    margin-top: var(--space-4);
    margin-bottom: var(--space-3);
  }

  .section-subtitle {
    color: var(--color-text-secondary);
    max-width: 600px;
    margin-inline: auto;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-4);
  }

  @media (max-width: 900px) {
    .features-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
  }

  .feature-card {
    padding: var(--space-6);
    border-radius: var(--radius-xl);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    transition: transform var(--duration-fast) var(--ease-out), border-color var(--duration-fast) var(--ease-out);
  }

  .feature-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-accent);
  }

  .feature-icon {
    font-size: 1.5rem;
    display: inline-flex;
    margin-bottom: var(--space-3);
  }

  .feature-card h3 {
    margin-bottom: var(--space-2);
    font-size: var(--text-lg);
  }

  .feature-card p {
    margin: 0;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .download-card {
    padding: var(--space-8);
    text-align: center;
  }

  .download-icon {
    width: 96px;
    height: 96px;
    border-radius: 22px;
    object-fit: cover;
    margin-bottom: var(--space-4);
  }

  .download-description {
    color: var(--color-text-secondary);
    margin-top: var(--space-3);
    margin-bottom: var(--space-6);
    line-height: 1.7;
  }

  .download-buttons {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .store-button {
    padding: var(--space-3) var(--space-5);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    text-decoration: none;
    background: transparent;
    font-weight: 600;
    min-width: 220px;
  }

  .store-button.disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .download-note {
    margin-top: var(--space-4);
    color: var(--color-muted);
    font-size: var(--text-sm);
  }

  .legal-section {
    padding-top: 0;
  }

  .legal-links {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    color: var(--color-muted);
    font-size: var(--text-sm);
  }

  .legal-links a {
    color: var(--color-muted);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .legal-links a:hover {
    color: var(--color-accent);
  }
</style>
