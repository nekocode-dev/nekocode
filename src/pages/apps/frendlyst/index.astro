---
import BaseLayout from '@/layouts/BaseLayout.astro';
import FrendLystNav from '@/components/nav/FrendLystNav.astro';
import Footer from '@/components/nav/Footer.astro';
import Container from '@/components/layout/Container.astro';
import Section from '@/components/layout/Section.astro';
import Button from '@/components/ui/Button.astro';
import Tag from '@/components/ui/Tag.astro';

const base = import.meta.env.BASE_URL;

const features = [
  {
    icon: '✨',
    title: 'Profile Worth',
    description: 'Grow a visible score from profile activity, support, streaks, and community attention.'
  },
  {
    icon: '📈',
    title: 'Friend Market',
    description: 'Find people through spotlight lists, profile value, and market-style discovery signals.'
  },
  {
    icon: '🎁',
    title: 'Gifts and Wallet',
    description: 'Send gifts, collect coins, track rewards, and make profile support feel visible.'
  },
  {
    icon: '🏛️',
    title: 'Clubs',
    description: 'Build communities with chat, member tools, announcements, and shared club vaults.'
  },
  {
    icon: '🏆',
    title: 'Leaderboards',
    description: 'Track fame, streaks, levels, achievements, and weekly social momentum.'
  },
  {
    icon: '🛡️',
    title: 'Safety Systems',
    description: 'Use verification, reporting, blocking, moderation, and account status controls.'
  }
];

const stats = [
  { value: 'Social', label: 'Discovery' },
  { value: 'Live', label: 'Economy' },
  { value: 'Clubs', label: 'Community' },
  { value: 'Safe', label: 'By Design' },
];

const icon = `${base}assets/projects/frendlyst/icon.png`;
const googlePlayUrl = '';
const appStoreUrl = '';
---

<BaseLayout
  title="FrendLyst | Social Discovery App"
  description="FrendLyst is a social discovery app with profile worth, gifts, clubs, leaderboards, and friend-market mechanics."
>
  <FrendLystNav slot="header" />

  <Section size="xl" class="hero-section">
    <Container>
      <div class="hero-grid">
        <div class="hero-content reveal-left">
          <div class="hero-badge">
            <span>Profiles • Gifts • Clubs • Rankings</span>
          </div>

          <h1 class="text-hero">
            <span class="gradient-text">Discover People</span><br/>
            Build Your Worth
          </h1>

          <p class="hero-description">
            Create a profile, meet new people, send gifts, join clubs, and grow your profile
            worth through activity, streaks, and community support.
          </p>

          <div class="hero-actions">
            <Button href="#download" variant="accent" size="lg">Get FrendLyst</Button>
            <Button href="#features" variant="secondary" size="lg">Explore Features</Button>
          </div>
        </div>

        <div class="phone-mockup reveal-right">
          <div class="phone-glow"></div>
          <div class="phone-frame">
            <div class="phone-screen" style={`--screen-image: url('${icon}')`}>
              <div class="phone-content">
                <img src={icon} alt="FrendLyst app logo" class="mockup-icon" />
                <span class="mockup-name">FrendLyst</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </Container>
  </Section>

  <Section class="stats-section">
    <Container size="narrow">
      <div class="stats-grid glass-panel">
        {stats.map((stat, index) => (
          <div class={`stat-item reveal stagger-${index + 1}`}>
            <div class="stat-value">{stat.value}</div>
            <div class="stat-label">{stat.label}</div>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  <Section id="features" size="lg" class="features-section">
    <Container>
      <div class="section-header reveal">
        <Tag variant="accent">Features</Tag>
        <h2 class="text-title-1">Built for social momentum</h2>
        <p class="section-subtitle">
          A social app where discovery, chat, gifts, clubs, and rankings all feed one visible reputation loop.
        </p>
      </div>

      <div class="features-grid">
        {features.map(feature => (
          <article class="feature-card">
            <span class="feature-icon">{feature.icon}</span>
            <h3>{feature.title}</h3>
            <p>{feature.description}</p>
          </article>
        ))}
      </div>
    </Container>
  </Section>

  <Section id="download" size="lg" class="download-section">
    <Container size="narrow">
      <div class="download-card glass-panel">
        <img src={icon} alt="FrendLyst" class="download-icon" />
        <h2 class="text-title-1">Get FrendLyst</h2>
        <p class="download-description">
          FrendLyst is currently in active development. Store links will be available at launch.
        </p>

        <div class="download-buttons">
          {googlePlayUrl ? (
            <a href={googlePlayUrl} target="_blank" rel="noopener noreferrer" class="store-button">Google Play</a>
          ) : (
            <button disabled class="store-button disabled">Android Coming Soon</button>
          )}

          {appStoreUrl ? (
            <a href={appStoreUrl} target="_blank" rel="noopener noreferrer" class="store-button">App Store</a>
          ) : (
            <button disabled class="store-button disabled">iOS Coming Soon</button>
          )}
        </div>

        <p class="download-note">Social discovery • Clubs • Gifts • Safety systems</p>
      </div>
    </Container>
  </Section>

  <Section class="legal-section">
    <Container size="narrow">
      <div class="legal-links">
        <a href={`${base}apps/frendlyst/privacy`}>Privacy Policy</a>
        <span class="divider">•</span>
        <a href={`${base}apps/frendlyst/terms`}>Terms of Service</a>
      </div>
    </Container>
  </Section>

  <Footer slot="footer" />
</BaseLayout>

<script>
  const initFrendLystHeroTilt = () => {
    const heroSection = document.querySelector('.hero-section');
    const phoneFrame = document.querySelector('.phone-frame');

    if (!heroSection || !phoneFrame) return;

    const handleMouseMove = (e) => {
      const { left, top, width, height } = heroSection.getBoundingClientRect();
      const x = (e.clientX - left) / width - 0.5;
      const y = (e.clientY - top) / height - 0.5;

      phoneFrame.style.setProperty('--tilt-x', `${y * -20}deg`);
      phoneFrame.style.setProperty('--tilt-y', `${x * 20}deg`);
    };

    const handleMouseLeave = () => {
      phoneFrame.style.setProperty('--tilt-x', '0deg');
      phoneFrame.style.setProperty('--tilt-y', '0deg');
    };

    heroSection.addEventListener('mousemove', handleMouseMove);
    heroSection.addEventListener('mouseleave', handleMouseLeave);
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFrendLystHeroTilt, { once: true });
  } else {
    initFrendLystHeroTilt();
  }
  document.addEventListener('astro:page-load', initFrendLystHeroTilt);
</script>

<style>
  .glass-panel {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-xl);
  }

  [data-theme="light"] .glass-panel {
    background: rgba(255, 255, 255, 0.85);
    border-color: rgba(0, 0, 0, 0.08);
  }

  .hero-section {
    position: relative;
    overflow: clip;
  }

  .hero-section::before {
    content: '';
    position: absolute;
    top: 12%;
    left: 12%;
    width: 380px;
    height: 380px;
    background: radial-gradient(circle, rgba(237, 106, 93, 0.18) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-section::after {
    content: '';
    position: absolute;
    bottom: 6%;
    right: 10%;
    width: 420px;
    height: 420px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: center;
    min-width: 0;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    min-width: 0;
    max-width: 590px;
  }

  @media (max-width: 768px) {
    .hero-grid {
      grid-template-columns: 1fr;
      text-align: center;
      justify-items: center;
      gap: var(--space-10);
    }

    .hero-content {
      width: 100%;
      max-width: min(100%, 560px);
    }

    .hero-content.reveal-left,
    .phone-mockup.reveal-right {
      transform: translateY(20px);
    }

    .hero-content.reveal-left.visible,
    .phone-mockup.reveal-right.visible {
      transform: translateY(0);
    }
  }

  .hero-badge {
    display: inline-block;
    padding: var(--space-2) var(--space-4);
    max-width: 100%;
    background: rgba(237, 106, 93, 0.15);
    border: 1px solid rgba(245, 230, 211, 0.3);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    color: #f5e6d3;
    margin-bottom: var(--space-6);
    overflow-wrap: anywhere;
  }

  [data-theme="light"] .hero-badge {
    color: #5f4327;
  }

  .gradient-text {
    background: linear-gradient(135deg, #ffffff, #f5e6d3);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-content h1 {
    margin-bottom: var(--space-6);
  }

  @media (max-width: 768px) {
    .hero-content h1 {
      font-size: clamp(2.65rem, 13.5vw, 4.5rem);
    }
  }

  .hero-description {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.7;
    margin-bottom: var(--space-8);
    max-width: 530px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .hero-actions :global(.btn) {
    flex: 0 0 210px;
    width: 210px;
  }

  @media (max-width: 768px) {
    .hero-description {
      margin-inline: auto;
    }

    .hero-actions {
      justify-content: center;
      width: 100%;
    }

    .hero-actions :global(.btn) {
      flex: 1 1 0;
      width: auto;
      min-width: min(100%, 180px);
      max-width: 220px;
    }
  }

  .phone-mockup {
    display: flex;
    justify-content: center;
    position: relative;
    perspective: 1000px;
    z-index: 10;
    width: 100%;
    min-width: 0;
  }

  .phone-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: min(340px, 86vw);
    height: min(600px, 132vw);
    background: radial-gradient(ellipse, rgba(237, 106, 93, 0.24) 0%, transparent 70%);
    filter: blur(45px);
    pointer-events: none;
    z-index: -1;
  }

  .phone-frame {
    background: #000;
    border-radius: 50px;
    padding: 12px;
    box-shadow:
      0 0 0 2px #333,
      0 0 0 4px #1a1a1a,
      0 24px 48px rgba(0, 0, 0, 0.45);
    transform-style: preserve-3d;
    transform: rotateX(var(--tilt-x, 0deg)) rotateY(var(--tilt-y, 0deg));
    transition: transform 0.1s cubic-bezier(0.2, 0, 0.2, 1);
    width: min(300px, 78vw);
    aspect-ratio: 1 / 2;
    height: auto;
    position: relative;
    will-change: transform;
  }

  .phone-frame::before {
    content: '';
    position: absolute;
    top: 24px;
    left: 50%;
    transform: translateX(-50%);
    width: 90px;
    height: 24px;
    background: #000;
    border-radius: 12px;
    z-index: 20;
  }

  .phone-frame::after {
    content: '';
    position: absolute;
    top: 100px;
    right: -6px;
    width: 4px;
    height: 60px;
    background: #2a2a2a;
    border-radius: 2px;
  }

  .phone-screen {
    width: 100%;
    height: 100%;
    border-radius: 40px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: linear-gradient(180deg, #0b0714 0%, #17111f 100%);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .phone-screen::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: var(--screen-image);
    background-position: center;
    background-size: cover;
    filter: blur(26px) saturate(1.25);
    transform: scale(1.08);
    opacity: 0.72;
  }

  .phone-screen::after {
    content: '';
    position: absolute;
    top: -50%;
    left: -100%;
    width: 200%;
    height: 200%;
    background: linear-gradient(
      45deg,
      transparent 40%,
      rgba(255, 255, 255, 0.05) 45%,
      transparent 50%
    );
    transform: rotate(25deg);
    pointer-events: none;
    z-index: 3;
  }

  .phone-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-8);
    transform: translateZ(20px);
  }

  .mockup-icon {
    width: 120px;
    height: 120px;
    border-radius: 28px;
    object-fit: cover;
    box-shadow:
      0 8px 24px rgba(0, 0, 0, 0.3),
      0 16px 48px rgba(237, 106, 93, 0.18);
    animation: float 6s ease-in-out infinite;
  }

  .mockup-name {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: 800;
    background: linear-gradient(135deg, #fff 0%, #f3f3f3 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    text-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
    letter-spacing: -0.03em;
  }

  .stats-section {
    padding-top: 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--space-4);
    padding: var(--space-6);
  }

  @media (max-width: 768px) {
    .stats-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .stat-item {
    text-align: center;
  }

  .stat-value {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 700;
    color: #ffffff;
  }

  .stat-label {
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--space-10);
  }

  .section-header h2 {
    margin-top: var(--space-4);
    margin-bottom: var(--space-3);
  }

  .section-subtitle {
    color: var(--color-text-secondary);
    max-width: 600px;
    margin-inline: auto;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-4);
  }

  @media (max-width: 900px) {
    .features-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
  }

  .feature-card {
    padding: var(--space-6);
    border-radius: var(--radius-xl);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    transition: transform var(--duration-fast) var(--ease-out), border-color var(--duration-fast) var(--ease-out);
  }

  .feature-card:hover {
    transform: translateY(-4px);
    border-color: rgba(245, 230, 211, 0.72);
  }

  .feature-icon {
    font-size: 1.5rem;
    display: inline-flex;
    margin-bottom: var(--space-3);
  }

  .feature-card h3 {
    margin-bottom: var(--space-2);
    font-size: var(--text-lg);
  }

  .feature-card p {
    margin: 0;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .download-card {
    padding: var(--space-8);
    text-align: center;
  }

  .download-icon {
    width: 96px;
    height: 96px;
    border-radius: 22px;
    object-fit: cover;
    margin-bottom: var(--space-4);
  }

  .download-description {
    color: var(--color-text-secondary);
    margin-top: var(--space-3);
    margin-bottom: var(--space-6);
    line-height: 1.7;
  }

  .download-buttons {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .store-button {
    padding: var(--space-3) var(--space-5);
    border-radius: var(--radius-md);
    border: 1px solid rgba(245, 230, 211, 0.72);
    color: #ffffff;
    text-decoration: none;
    background: transparent;
    font-weight: 600;
    min-width: 220px;
  }

  .store-button.disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .download-note {
    margin-top: var(--space-4);
    color: var(--color-muted);
    font-size: var(--text-sm);
  }

  .legal-section {
    padding-top: 0;
  }

  .legal-links {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    color: var(--color-muted);
    font-size: var(--text-sm);
  }

  .legal-links a {
    color: var(--color-muted);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .legal-links a:hover {
    color: #ffffff;
  }
</style>
