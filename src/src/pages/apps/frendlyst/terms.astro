---
import BaseLayout from '@/layouts/BaseLayout.astro';
import FrendLystNav from '@/components/nav/FrendLystNav.astro';
import Footer from '@/components/nav/Footer.astro';
import Container from '@/components/layout/Container.astro';
import Section from '@/components/layout/Section.astro';

const base = import.meta.env.BASE_URL;
const LAST_UPDATED = 'April 24, 2026';

const summaryPoints = [
  'Virtual only - no cash value, no cash-out, no securities, and no real ownership of people.',
  'Safety rules - reports, blocks, filtering, moderation, and bans may be used to protect the service.',
  'Limits on liability - claims and damages are limited to the fullest extent allowed by law.',
];

const sections = [
  {
    id: 'acceptance',
    title: 'Agreement and Operator',
    content: [
      'Agreement: By creating an account, accessing FrendLyst, or using any FrendLyst feature, you agree to these Terms of Service and the Privacy Policy.',
      'Independent Developer: FrendLyst is operated by an independent developer based in the Philippines, not by a corporation unless a later notice says otherwise. In these Terms, "FrendLyst", "we", "us", and "our" mean that independent operator.',
      'Legal Capacity: You represent that you can form a binding agreement and that your use of the app is lawful where you live.',
      'Age Requirement: You must be at least 18 years old to use FrendLyst. If we learn that an account belongs to a person under 18, we may delete or restrict it.',
      'Policy Updates: Some features may have extra rules inside the app. Those rules are part of these Terms when they apply to that feature.',
    ],
  },
  {
    id: 'account',
    title: 'Account Responsibilities',
    content: [
      'Accurate Information: You must provide accurate account, profile, age, and contact information and keep it updated.',
      'One Real User: Do not create fake, duplicate, shared, automated, or misleading accounts to manipulate discovery, rewards, rankings, ownership, referrals, moderation, or purchases.',
      'Account Security: You are responsible for your login credentials and for activity under your account. Use a strong password and report unauthorized access promptly.',
      'No Account Transfers: You may not sell, rent, lend, transfer, or trade your account, profile, virtual balances, profile number, ownership position, subscription access, or app privileges outside FrendLyst.',
      'Contact: Report account security concerns or support issues to nekocode.dev@gmail.com.',
    ],
  },
  {
    id: 'virtual-game',
    title: 'Virtual Social Game',
    content: [
      'Entertainment Only: FrendLyst is a social game with virtual-only mechanics. It is not a bank, broker, exchange, investment product, gambling product, employment platform, payroll service, dating service, escort service, or financial adviser.',
      'No Real-World Value: Coins, gems, profile prices, profile numbers, friend ownership, wages, rewards, rankings, net worth, fame, badges, items, and all other values are in-app only. They have no real-world monetary value and cannot be sold, redeemed, withdrawn, transferred off-platform, or cashed out.',
      'No Ownership of People: In-app words like buy, friend, owner, circle, work, wage, value, and net worth are game labels only. They never create ownership, control, employment, agency, partnership, investment, securities, profit-sharing, or property rights over any person or real-world asset.',
      'Changing Economy: We may rebalance prices, rewards, taxes, burns, limits, rankings, subscriptions, quests, items, randomized outcomes, or game rules to protect fairness, safety, legal compliance, and service health.',
      'No Guaranteed Outcome: Premium features, boosts, ads, gifts, purchases, visibility, discovery, ownership, and participation do not guarantee matches, popularity, income, rewards, rankings, profile views, messages, or any other result.',
    ],
  },
  {
    id: 'purchases',
    title: 'Purchases and Subscriptions',
    content: [
      'Official Stores: Digital purchases and subscriptions in the mobile app must use the official Apple App Store or Google Play billing flow when required by platform rules.',
      'Store Terms Apply: Apple, Google, or another approved store may process payment, taxes, billing support, renewals, cancellations, and refunds under their own terms.',
      'Subscriptions: Subscriptions renew automatically unless cancelled through the store before renewal. Deleting the app or deleting your account may not cancel a store subscription by itself.',
      'Virtual Currency: Purchased consumable currency does not expire solely because time passes, but it may be consumed, adjusted, reversed, suspended, or removed for refunds, chargebacks, fraud, exploitation, legal reasons, account deletion, or Terms violations.',
      'Earned Rewards: Free, promotional, ad-based, referral, or earned rewards may be limited, changed, corrected, or expired as explained in the app or as needed for abuse prevention.',
      'Randomized Rewards: If a paid feature offers randomized virtual items or outcomes, the app should disclose material odds or rules before purchase. Random outcomes are entertainment only and never have cash value.',
      'Refunds: Purchases are generally final except where required by law or store policy. Contact nekocode.dev@gmail.com for support, but store refunds may need to be requested directly from Apple or Google.',
    ],
  },
  {
    id: 'user-content',
    title: 'User Content',
    content: [
      'Your Content: You are responsible for profiles, photos, posts, chat messages, club content, reports, support tickets, display names, bios, and anything else you submit.',
      'Required Rights: You must own your content or have permission to upload it. Do not post content that infringes copyright, trademark, privacy, publicity, or other rights.',
      'License to Operate: You grant FrendLyst a worldwide, non-exclusive, royalty-free license to host, store, copy, display, format, transmit, moderate, remove, and otherwise use your content only as needed to operate, improve, secure, promote, and enforce the app.',
      'Public Surfaces: Profile details, avatar images, posts, reactions, club participation, ownership activity, rankings, profile numbers, and game stats may be visible to other users depending on the feature.',
      'Moderation Evidence: Reported content and relevant chat snippets may be reviewed by moderators and safety systems to enforce these Terms, protect users, respond to disputes, or comply with law.',
      'Removal: We may remove, hide, limit, label, preserve, or report content when we believe it violates these Terms, creates risk, infringes rights, or may be unlawful.',
    ],
  },
  {
    id: 'conduct',
    title: 'Community Rules',
    content: [
      'Respect People: Do not harass, bully, stalk, threaten, shame, exploit, objectify, intimidate, extort, blackmail, or coordinate harm against another person.',
      'No Sexual or Exploitative Misuse: Do not use FrendLyst for pornography, prostitution, escorting, trafficking, sexual solicitation, sexual exploitation, non-consensual intimate content, or sexual content involving or appearing to involve minors.',
      'No Child Safety Violations: Any child sexual abuse material, grooming, sexualized minor content, or attempt to contact minors for sexual purposes is forbidden and may be reported to law enforcement or appropriate authorities.',
      'No Hate or Violence: Do not post hate speech, violent threats, terrorist or extremist content, instructions for harm, or content that attacks protected characteristics.',
      'No Defamation or Privacy Abuse: Do not post cyberlibel, malicious false claims, doxxing, private contact details, identification documents, private conversations, or personal data without lawful permission.',
      'No Scams or Illegal Activity: Do not use FrendLyst for fraud, phishing, malware, illegal goods, regulated goods, gambling, real-money trading, money transmission, loan collection, harassment, or other unlawful activity.',
      'No Manipulation: Do not use bots, scripts, collusion, ring trading, fake engagement, review manipulation, referral abuse, chargeback abuse, scraping, vulnerability exploitation, or any method intended to distort app systems.',
    ],
  },
  {
    id: 'safety',
    title: 'Safety and Moderation',
    content: [
      'Report and Block: FrendLyst provides reporting and blocking tools. Use them when content or behavior feels unsafe, abusive, illegal, or against these Terms.',
      'Moderation Actions: Depending on the severity, evidence, risk, user history, repeat behavior, and legal or safety impact of the offense, we may warn, mute, rate-limit, remove content, restrict features, reverse rewards, freeze balances, suspend accounts, ban accounts, preserve evidence, or escalate serious issues.',
      'Automated Systems: We may use filters, spam scoring, abuse detection, fraud rules, and AI-assisted moderation to triage content and reports. Final action may also involve human review where available.',
      'No Duty to Monitor Everything: We work to moderate the service, but we cannot review every interaction before it happens and cannot guarantee that every user will behave safely.',
      'Emergencies: FrendLyst is not an emergency service. If you are in danger, contact local emergency services immediately.',
      'Law Enforcement: We may disclose information to law enforcement, regulators, courts, app stores, or safety organizations when we believe disclosure is legally required or necessary to prevent harm.',
    ],
  },
  {
    id: 'security',
    title: 'Security Rules',
    content: [
      'No Interference: Do not access, test, scan, attack, reverse engineer, overload, bypass, or interfere with FrendLyst systems except through lawful, authorized app use.',
      'No Unauthorized Data Collection: Do not scrape, harvest, sell, index, or republish user data, app data, private APIs, or platform data without written permission.',
      'Responsible Disclosure: If you discover a security issue, report it to nekocode.dev@gmail.com and do not exploit, disclose, or access user data beyond what is necessary to demonstrate the issue.',
      'Service Protection: We may block traffic, devices, accounts, purchases, or requests that appear abusive, fraudulent, automated, risky, or harmful to the service.',
    ],
  },
  {
    id: 'privacy',
    title: 'Privacy and Data',
    content: [
      'Privacy Policy: The Privacy Policy explains what personal data we collect, why we process it, where it may be processed, how long we keep it, and how to exercise privacy rights.',
      'Philippine Privacy Law: As a Philippines-based operator, we aim to comply with the Data Privacy Act of 2012 and other applicable privacy laws.',
      'Public Content: Do not post personal data you do not want other users to see. Some app features are intentionally public or semi-public.',
      'Data Requests: Contact nekocode.dev@gmail.com or use in-app settings for access, correction, deletion, objection, restriction, portability, or other privacy requests where available by law.',
    ],
  },
  {
    id: 'availability',
    title: 'Availability and Changes',
    content: [
      'As-Is Service: FrendLyst is provided on an as-is and as-available basis. We do not promise uninterrupted, secure, error-free, or unchanged service.',
      'Feature Changes: We may add, remove, suspend, rename, redesign, limit, or stop features at any time, including social features, economy features, ads, purchases, subscriptions, clubs, rankings, and rewards.',
      'Maintenance: The app may be unavailable during maintenance, outages, security incidents, store review, legal review, third-party service failures, or force majeure events.',
      'Third-Party Services: FrendLyst depends on third-party services such as hosting, authentication, app stores, push notifications, ads, moderation, maps, and error monitoring. We are not responsible for third-party outages or terms.',
    ],
  },
  {
    id: 'termination',
    title: 'Suspension and Deletion',
    content: [
      'Your Right: You may stop using FrendLyst at any time and may request or perform account deletion through Settings where available.',
      'Our Right: We may suspend, restrict, or terminate access if we believe you violated these Terms, created risk, broke the law, abused systems, or harmed users or the service.',
      'Effect of Deletion: Account deletion is intended to be permanent. You may lose profile content, messages, balances, purchases, subscriptions in the app, rankings, rewards, ownership positions, and access history.',
      'Subscriptions After Deletion: You are responsible for cancelling any auto-renewing subscription through Apple, Google, or the applicable store.',
      'Retention: We may retain limited records when needed for fraud prevention, safety, legal compliance, dispute handling, tax/accounting, backup integrity, security logs, or enforcement history.',
    ],
  },
  {
    id: 'disclaimers',
    title: 'Disclaimers and Liability',
    content: [
      'No Professional Advice: FrendLyst does not provide financial, investment, legal, tax, employment, health, relationship, or safety advice.',
      'User Conduct: Users are responsible for their own content, decisions, interactions, meetings, purchases, and conduct. We are not liable for user-generated content or user behavior to the fullest extent allowed by law.',
      'No Indirect Damages: To the fullest extent permitted by law, we are not liable for indirect, incidental, special, consequential, exemplary, punitive, or lost-profit damages.',
      'Liability Cap: To the fullest extent permitted by law, our total liability for all claims is limited to the greater of the amount you paid through official app stores for FrendLyst in the 12 months before the claim or PHP 5,000.',
      'Non-Excludable Rights: Nothing in these Terms limits rights that cannot legally be waived, including rights under applicable consumer, privacy, and safety laws.',
    ],
  },
  {
    id: 'indemnity',
    title: 'Your Indemnity',
    content: [
      'Indemnity: To the fullest extent permitted by law, you agree to defend, indemnify, and hold harmless the FrendLyst independent developer from claims, losses, damages, liabilities, penalties, costs, and expenses arising from your content, conduct, purchases, account misuse, law violations, rights violations, or breach of these Terms.',
      'Cooperation: We may control the defense of claims involving the service, and you agree to cooperate reasonably with us.',
    ],
  },
  {
    id: 'disputes',
    title: 'Governing Law and Disputes',
    content: [
      'Governing Law: These Terms are governed by the laws of the Republic of the Philippines, without regard to conflict-of-law rules, unless mandatory law in your location requires otherwise.',
      'Informal Resolution: Before filing a claim, you agree to contact nekocode.dev@gmail.com with a clear description of the issue and allow 30 days for informal resolution, except for urgent safety, privacy, intellectual property, injunction, or law-enforcement matters.',
      'Individual Claims: To the fullest extent permitted by law, disputes must be brought individually and not as a class, collective, representative, or private attorney general action.',
      'Venue: Claims may be brought in courts or forums in the Philippines where venue is proper under applicable law, unless mandatory consumer law gives you another venue.',
      'Severability: If any part of these Terms is unenforceable, the rest remains effective to the fullest extent allowed by law.',
    ],
  },
  {
    id: 'changes',
    title: 'Changes to Terms',
    content: [
      'Updates: We may update these Terms as the app, law, store rules, safety needs, or business model changes.',
      'Material Changes: We will try to give reasonable in-app or email notice for material changes, usually at least 30 days where practical.',
      'Immediate Changes: Changes may take effect immediately when needed for security, legal compliance, abuse prevention, new features, or urgent service protection.',
      'Continued Use: If you keep using FrendLyst after updated Terms take effect, you accept the updated Terms. If you do not agree, stop using the app and delete your account.',
    ],
  },
];

const splitLead = (item: string) => {
  const index = item.indexOf(':');
  if (index === -1) return { lead: '', body: item };
  return {
    lead: item.slice(0, index + 1),
    body: item.slice(index + 1),
  };
};
---

<BaseLayout
  title="Terms of Service | FrendLyst"
  description="Terms of Service for FrendLyst social discovery app"
>
  <FrendLystNav slot="header" />

  <Section size="lg" class="legal-page">
    <Container size="narrow">
      <a href={`${base}apps/frendlyst`} class="back-link">← Back to FrendLyst</a>

      <div class="legal-header glass-panel">
        <span class="legal-icon" aria-hidden="true">📜</span>
        <div>
          <h1 class="text-title-1">Terms of Service</h1>
          <p class="legal-subtitle">
            These terms explain the rules for using FrendLyst as an 18+ virtual social game operated by an independent developer in the Philippines.
          </p>
        </div>
        <p class="last-updated">Last Updated: {LAST_UPDATED}</p>
      </div>

      <div class="legal-content glass-panel">
        <div class="highlight-box">
          <h2>Important Legal Agreement</h2>
          <p>
            FrendLyst includes user-generated content, chats, virtual currency, subscriptions, ads, and social game mechanics. Key points:
          </p>
          <ul>
            {summaryPoints.map(point => (
              <li>{point}</li>
            ))}
          </ul>
        </div>

        {sections.map(section => (
          <section id={section.id}>
            <h2>{section.title}</h2>
            <ul>
              {section.content.map(item => {
                const { lead, body } = splitLead(item);
                return (
                  <li>
                    {lead && <strong>{lead}</strong>}
                    {body}
                  </li>
                );
              })}
            </ul>
          </section>
        ))}
      </div>
    </Container>
  </Section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    margin-bottom: var(--space-6);
    color: rgba(255, 255, 255, 0.72);
    font-size: var(--text-sm);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .back-link:hover {
    color: var(--color-text);
  }

  .glass-panel {
    background: rgba(14, 14, 16, 0.86);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--radius-xl);
  }

  [data-theme="light"] .glass-panel {
    background: rgba(255, 255, 255, 0.86);
    border-color: rgba(0, 0, 0, 0.08);
  }

  .legal-header {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    gap: var(--space-4);
    padding: var(--space-6);
    margin-bottom: var(--space-8);
  }

  .legal-icon {
    font-size: var(--text-3xl);
    line-height: 1;
  }

  .legal-subtitle {
    max-width: 560px;
    color: rgba(255, 255, 255, 0.78);
    font-size: var(--text-base);
    line-height: 1.7;
    margin: var(--space-2) 0 0;
  }

  .last-updated {
    margin-left: auto;
    font-size: var(--text-xs);
    color: #f5e6d3;
    font-family: monospace;
    white-space: nowrap;
  }

  .legal-content {
    line-height: 1.8;
    padding: var(--space-6);
    font-size: var(--text-base);
  }

  .legal-content section {
    padding-block: var(--space-8);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .legal-content section:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  @media (max-width: 768px) {
    .legal-header,
    .legal-content {
      padding: var(--space-4);
    }

    .last-updated {
      margin-left: 0;
      width: 100%;
    }
  }

  .legal-content h2 {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    color: #ffffff;
    margin-bottom: var(--space-4);
  }

  .legal-content p {
    color: rgba(255, 255, 255, 0.82);
    margin-bottom: var(--space-4);
  }

  .legal-content ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .legal-content li {
    padding: var(--space-2) 0 var(--space-2) var(--space-6);
    color: rgba(255, 255, 255, 0.84);
    position: relative;
  }

  .legal-content li::before {
    content: '›';
    position: absolute;
    left: 0;
    color: #f5e6d3;
    font-weight: bold;
  }

  .legal-content strong {
    color: #ffffff;
    font-weight: 700;
  }

  .highlight-box {
    padding: var(--space-6);
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-4);
    background: rgba(245, 230, 211, 0.08);
    border: 1px solid rgba(245, 230, 211, 0.22);
  }
</style>
